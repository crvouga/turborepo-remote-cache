{
  "name": "turborepo-remote-cache",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "pkgs/*"
  ],
  "scripts": {
    "check": "bun run ci:format && bun run test:scripts && turbo run tc lint test build",
    "check:vault-secrets": "vault run -- bun run scripts/check-vault-secrets.ts",
    "check:vault-secrets:prd": "vault run --config prd -- bun run scripts/check-vault-secrets.ts",
    "ci:format": "prettier --check .",
    "deploy": "vault run --config prd -- bun run --filter @apps/api deploy",
    "dev": "bun run --filter @apps/api dev",
    "format": "prettier --write .",
    "gh": "open https://github.com/crvouga/turborepo-remote-cache/actions/workflows/deployment-pipeline.yml",
    "seed": "bun run scripts/ensure-vault-secrets.ts",
    "seed:turbo-client": "vault run -- bun run scripts/seed-turbo-client-secrets.ts",
    "seed:turbo-client:mirror-prd": "bun run scripts/seed-turbo-client-secrets.ts -- --mirror-prd",
    "seed:turbo-client:prd": "vault run --config prd -- bun run scripts/seed-turbo-client-secrets.ts",
    "setup": "bun run --filter @apps/api setup && bun run scripts/ensure-vault-secrets.ts",
    "smoke": "vault run -- bun run scripts/smoke-test-cache.ts",
    "smoke:prd": "vault run --config prd -- bun run scripts/smoke-test-cache.ts",
    "test:scripts": "bun test scripts"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-lingui": "catalog:",
    "eslint-plugin-naming": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=22"
  },
  "catalog": {
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "aws4fetch": "^1.0.20",
    "eslint": "^9.25.0",
    "eslint-plugin-lingui": "^0.13.1",
    "eslint-plugin-naming": "^0.1.10",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "hono": "^4.7.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.16",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1"
  }
}
