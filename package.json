{
  "name": "turborepo-remote-cache",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "pkgs/*"
  ],
  "scripts": {
    "check": "bun run ci:format && turbo run tc lint test build",
    "check:doppler-secrets": "bun run scripts/doppler-run.ts -- bun run scripts/check-doppler-secrets.ts",
    "check:doppler-secrets:prd": "DOPPLER_CONFIG=prd bun run scripts/doppler-run.ts -- bun run scripts/check-doppler-secrets.ts",
    "ci:format": "prettier --check .",
    "deploy": "DOPPLER_CONFIG=prd bun run scripts/doppler-run.ts -- bun run --filter @apps/api deploy",
    "dev": "bun run --filter @apps/api dev",
    "format": "prettier --write .",
    "gh:seed-doppler-service-token": "DOPPLER_CONFIG=prd bun run scripts/seed-github-doppler-service-token.ts",
    "setup": "bun run --filter @apps/api setup && bun run scripts/ensure-doppler-secrets.ts"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-naming": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=22"
  },
  "catalog": {
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "aws4fetch": "^1.0.20",
    "eslint": "^9.25.0",
    "eslint-plugin-naming": "^0.1.10",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "hono": "^4.7.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.16",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "wrangler": "^4.54.0"
  }
}
