{
  "name": "@apps/api",
  "version": "1.0.0",
  "private": true,
  "exports": {
    "./*": [
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts"
    ]
  },
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "deploy": "bun run scripts/deploy.ts",
    "dev": "wrangler dev --port 8787",
    "lint": "eslint src --max-warnings 0",
    "setup": "bun run scripts/setup-dev-vars.ts",
    "tc": "tsc --noEmit -p ../../tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@pkgs/assert": "workspace:*",
    "@pkgs/logger": "workspace:*",
    "@pkgs/object-store": "workspace:*",
    "@pkgs/secret-store": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
